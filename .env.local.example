# Supabase — li trovi in Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=la-tua-anon-key

# Gemini — la trovi su https://aistudio.google.com/app/apikey
# NON deve avere il prefisso NEXT_PUBLIC_: resta segreta, usata solo server-side
GEMINI_API_KEY=la-tua-gemini-api-key
